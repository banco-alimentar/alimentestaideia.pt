@page
@model LoginModel

<h1>@Localizer["Login"]</h1>
@if (Model.ShowMergeOffer)
{
    <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading">@Localizer["MergeOfferTitle"]</h5>
        <p>@Localizer["MergeOfferMessage", Model.PendingExternalProviderDisplayName, Model.MaskedSourceEmail]</p>
        <p class="mb-0">@Localizer["MergeOfferDetails"]</p>
        <hr />
        <div class="d-flex flex-column flex-sm-row flex-wrap">
            <form asp-page-handler="ConfirmMerge" method="post" class="mb-2 mr-sm-2">
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <button type="submit" class="btn btn-primary">@Localizer["ConfirmMergeAction"]</button>
            </form>
            <form asp-page-handler="CancelLink" method="post" class="mb-2">
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <button type="submit" class="btn btn-outline-secondary">@Localizer["CancelMergeAction"]</button>
            </form>
        </div>
    </div>
}
else if (Model.ShowLinkConflictHelp)
{
    <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading">@Localizer["LinkConflictTitle", Model.PendingExternalProviderDisplayName]</h5>
        @switch (Model.LinkConflictBlockReason)
        {
            case nameof(BancoAlimentar.AlimentaEstaIdeia.Web.Services.AccountMergeBlockReason.EmailMismatch):
                <p>@Localizer["LinkConflictEmailMismatch", Model.PendingExternalProviderDisplayName, Model.MaskedExternalEmail, Model.MaskedSourceEmail]</p>
                break;
            case nameof(BancoAlimentar.AlimentaEstaIdeia.Web.Services.AccountMergeBlockReason.ProtectedAccount):
                <p>@Localizer["LinkConflictProtectedAccount", Model.PendingExternalProviderDisplayName]</p>
                break;
            case nameof(BancoAlimentar.AlimentaEstaIdeia.Web.Services.AccountMergeBlockReason.MissingExternalEmail):
                <p>@Localizer["LinkConflictMissingExternalEmail", Model.PendingExternalProviderDisplayName]</p>
                break;
            default:
                <p>@Localizer["LinkConflictGeneric", Model.PendingExternalProviderDisplayName]</p>
                break;
        }
        <hr />
        <p class="mb-2"><strong>@Localizer["LinkConflictSolutionsTitle"]</strong></p>
        <ul class="mb-0">
            <li>@Localizer["LinkConflictSolutionSignInWithProvider", Model.PendingExternalProviderDisplayName]</li>
            <li>@Localizer["LinkConflictSolutionUseMatchingEmail", Model.PendingExternalProviderDisplayName]</li>
            <li>@Localizer["LinkConflictSolutionRemoveFromOtherAccount", Model.PendingExternalProviderDisplayName]</li>
        </ul>
        <hr />
        <form asp-page-handler="CancelLink" method="post">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit" class="btn btn-outline-secondary">@Localizer["CancelMergeAction"]</button>
        </form>
    </div>
}
else if (Model.LinkExternalLogin && !string.IsNullOrEmpty(Model.PendingExternalProviderDisplayName))
{
    <div class="alert alert-info" role="alert">
        @Localizer["LinkExternalLoginMessage", Model.PendingExternalProviderDisplayName]
    </div>
}
<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <h4>@Localizer["LoginLocalAccount"]</h4>
                <hr />
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Input.Email">@IdentitySharedLocalizer["Email"]</label>
                    <input asp-for="Input.Email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.Password">@IdentitySharedLocalizer["Password"]</label>
                    <input asp-for="Input.Password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <div class="checkbox">
                        <label asp-for="Input.RememberMe">
                            <input asp-for="Input.RememberMe" />
                            @Localizer["RememberMe"]
                        </label>
                    </div>
                </div>
                <div class="form-group">
                    <button id="loginBtn" type="submit" class="btn btn-primary">@Localizer["Login"]</button>
                </div>
                <div class="form-group">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">@Localizer["ForgotPassword"]</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["RegisterAsNewUser"]</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">@Localizer["ResendEmailConfirmation"]</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h4>@IdentitySharedLocalizer["ExternalService"]</h4>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            There are no external authentication services configured. See <a href="https://go.microsoft.com/fwlink/?LinkID=532715">this article</a>
                            for details on setting up this ASP.NET application to support logging in via external services.
                        </p>
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>

                            @foreach (var provider in Model.ExternalLogins)
                            {
                                <button type="submit" class="btn btn-block btn-social btn-@provider.DisplayName.ToLowerInvariant() social-login-button" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    <span style="margin-top:4px" class="fab fa-@provider.DisplayName.ToLowerInvariant()"></span>
                                    Sign in with @provider.DisplayName
                                </button>
                            }


                        </div>
                    </form>
                }
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
