@page
@model CampaignsHistoryModel
@using BancoAlimentar.AlimentaEstaIdeia.Web.Services
@inject ReferralImageService ReferralImageService
@inject ReferralQrCodeService ReferralQrCodeService

<div class="container">
    <div class="row">
        <span class="col">
            <h3>@Localizer["AvailableCampaignsTitle"]</h3>
        </span>
        <span class="col text-right">
            <a href="#create_section" class="btn btn-outline-primary">+</a>
        </span>
    </div>
    <hr class="my-4" />
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @if (Model.Referrals?.Count > 0)
        {    
            @foreach (var item in Model.Referrals)
            {
                <div class="col">
                    <div class="card">
                        <div class="card-header">
                            <h4 class="card-header-title">@HttpUtility.UrlDecode(item.Code)</h4>
                        </div>
                        <div class="card-body text-center">
                            @{
                                var referralImageUrl = ReferralImageService.ResolveUrl(item.ImageUrl);
                            }
                            @if (!string.IsNullOrEmpty(referralImageUrl))
                            {
                                <img src="@referralImageUrl"
                                     alt="@item.Name"
                                     style="max-width: 100%; max-height: 140px; object-fit: contain;" />
                                <br />
                            }
                            <span class="card-subtitle mb-0">@Localizer["TotalDonated"]</span>
                            <h2 class="h3 text-primary">€ @Math.Round(item.Donations.Where(d => d.PaymentStatus == PaymentStatus.Payed).Sum(d => d.DonationAmount),2) EUR</h2>
                            <a href='@Url.Content($"~/Referral/{item.Code}")' class="card-link">@Request.Scheme://@Request.Host.Value@Url.Content($"~/Referral/{item.Code}")</a>
                            @if (item.Active)
                            {<div>Activa</div>}
                            else
                            {<div>Não activa</div>}
                            @if (item.IsPublic)
                            {<div>Publica</div>}
                            else
                            {<div>Privada</div>}
                            @{
                                var donationUrl = $"{Request.Scheme}://{Request.Host.Value}{Url.Content($"~/Referral/{item.Code}")}";
                                var qrCodeDataUri = ReferralQrCodeService.CreateDataUri(donationUrl);
                            }
                            <div class="mt-3">
                                <span class="card-subtitle">@Localizer["ReferralQrCodeTitle"]</span>
                                @if (!string.IsNullOrEmpty(qrCodeDataUri))
                                {
                                    <img src="@qrCodeDataUri"
                                         alt="@Localizer["ReferralQrCodeTitle"]"
                                         width="120"
                                         height="120"
                                         class="d-block mx-auto my-2" />
                                }
                                <small class="text-muted d-block">@Localizer["ReferralQrCodeHelp"]</small>
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-end align-items-center">
                            <a href='@Url.Page("/Account/Manage/CampaignEdit", new { id = item.Id, area = "Identity"})' class="btn btn-primary">@Localizer["CampaignEdit"]</a>
                            &nbsp;
                            <a href='@Url.Page("/Account/Manage/CampaignDetail", new { id = item.Id, area = "Identity"})' class="btn btn-primary">@Localizer["CampaignDetails"]</a>
                        </div>
                    </div>
                    <br />
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning" role="alert">
                @Localizer["EmptyCampaignsAlert"]
            </div>
        }
    </div>
    <hr class="my-4" />
    <form id="create_section" method="post" asp-page="./CampaignsHistory">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row form-group">
            <h4 class="card-header-title">
                @Localizer["NewCampaignTitle"]
            </h4>
            <ul>
                <li>@Localizer["IntroMessage1"]</li>
                <li>@Localizer["IntroMessage2"]</li>
                <li>@Localizer["IntroMessage3"]</li> 
            </ul>
            <div class="input-group mb-3">
                <span class="input-group-text" id="basic-addon1">@Localizer["CampaingnCode"]</span>
                <input asp-for="Code"
                       class="form-control"
                       placeholder="@Localizer["CampaignCodeDescription"]"
                       aria-label="@Localizer["CampaingnCode"]"
                       aria-describedby="basic-addon1" />
                <button class="btn btn-primary" type="submit" id="create-campaign-submit">@Localizer["CreateCampaignActionText"] <i class="tio-ok"></i></button>
            </div>
            <span asp-validation-for="Code" class="text-danger d-block"></span>
        </div>
        @if (Model.ActiveCampaignExists)
        {
            <div class="align-items-center text-danger">
                @Localizer["CampaignAlreadyExists"]
            </div> 
        }
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var form = document.getElementById('create_section');
            if (!form) {
                return;
            }

            function scrollToCreateSection() {
                form.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            if (window.jQuery) {
                jQuery(function ($) {
                    function hookValidationScroll() {
                        var $form = $('#create_section');
                        var validator = $form.data('validator');
                        if (!validator) {
                            return false;
                        }

                        var previousInvalidHandler = validator.settings.invalidHandler;
                        validator.settings.invalidHandler = function (event, validation) {
                            if (previousInvalidHandler) {
                                previousInvalidHandler.call(this, event, validation);
                            }

                            scrollToCreateSection();
                        };
                        return true;
                    }

                    if (!hookValidationScroll()) {
                        setTimeout(hookValidationScroll, 0);
                    }
                });
            }

            @if (!ViewContext.ViewData.ModelState.IsValid)
            {
                @:scrollToCreateSection();
            }
        })();
    </script>
}