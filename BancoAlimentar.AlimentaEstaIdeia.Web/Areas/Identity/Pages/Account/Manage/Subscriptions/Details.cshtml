@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Identity.Pages.Account.Manage.Subscriptions.DetailsModel
@using BancoAlimentar.AlimentaEstaIdeia.Model

@{
    ViewData["Title"] = Localizer["Title"].Value;
    Layout = "_LayoutSubscription";
}

@section Css {
    <environment include="Development">
        <link href="~/lib/datatables/css/jquery.dataTables.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-bs4/dataTables.bootstrap4.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.css" rel="stylesheet" />
    </environment>
    <environment exclude="Development">
        <link href="~/lib/datatables/css/jquery.dataTables.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-bs4/dataTables.bootstrap4.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.min.css" rel="stylesheet" />
    </environment>
}

<h1>@Localizer["Title"]</h1>

<div>
    <h4>@Localizer["Subscription"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Localizer["Created"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Subscription.Created)
        </dd>
        <dt class="col-sm-2">
            @Localizer["StartTime"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Subscription.StartTime)
        </dd>
        <dt class="col-sm-2">
            @Localizer["ExpirationTime"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Subscription.ExpirationTime)
        </dd>
        <dt class="col-sm-2">
            @Localizer["SubscriptionType"]
        </dt>
        <dd class="col-sm-10">
            @switch (Model.Subscription.SubscriptionType)
            {
                case SubscriptionPaymentType.CC:
                    @IdentitySharedLocalizer["CreditCard"]
                    break;
                case SubscriptionPaymentType.DD:
                    @Localizer["DirectDebit"]
                    break;
                default:
                    @Model.Subscription.SubscriptionType
                    break;
            }
        </dd>
        <dt class="col-sm-2">
            @Localizer["Frequency"]
        </dt>
        <dd class="col-sm-10">
            @IdentitySharedLocalizer[Model.Subscription.Frequency]
        </dd>
        <dt class="col-sm-2">
            @Localizer["Status"]
        </dt>
        <dd class="col-sm-10">
            @switch (Model.Subscription.Status)
            {
                case SubscriptionStatus.Active:
                    @IdentitySharedLocalizer["Active"]
                    break;
                case SubscriptionStatus.Inactive:
                    @IdentitySharedLocalizer["Inactive"]
                    break;
                case SubscriptionStatus.Created:
                    @Localizer["CreatedStatus"]
                    break;
                case SubscriptionStatus.Capture:
                    @Localizer["Capture"]
                    break;
                case SubscriptionStatus.Error:
                    @Localizer["Error"]
                    break;
                default:
                    @Model.Subscription.Status
                    break;
            }
        </dd>
    </dl>
    <hr />
    <h2>@Localizer["Donations"]</h2>
    <table id="donations" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Created"]</th>
                <th>@Localizer["Amount"]</th>
                <th>@Localizer["FoodBank"]</th>
                <th>@Localizer["Payment"]</th>
            </tr>
        </thead>
    </table>
</div>
<div>
    @{
        if (Model.Subscription.Status != SubscriptionStatus.Inactive)
        {
            <a class="btn btn-danger" asp-page="./Delete" asp-route-id="@Model.Subscription.Id">@Localizer["CancelSubscription"]</a> @:|
            <a class="btn btn-primary" asp-page="./Edit" asp-route-id="@Model.Subscription.Id">@Localizer["Edit"]</a> @:|
        }

    }

    <a class="btn btn-light" asp-page="./Index">@Localizer["BackToList"]</a>
</div>

@section Scripts {
    <environment include="Development">
        <script src="~/lib/datatables/js/jquery.dataTables.js"></script>
        <script src="~/lib/datatables.net-bs4/dataTables.bootstrap4.js"></script>
        <script src="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.js"></script>
        <script src="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
        <script src="~/lib/datatables.net-bs4/dataTables.bootstrap4.min.js"></script>
        <script src="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.min.js"></script>
        <script src="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.min.js"></script>
    </environment>

    <script type="text/javascript">
    $(function () {
    $.ajax("Details?handler=DataTableData&id=" + @Model.Subscription.Id, { method: "get" })
        .then(function (data) {
            $('#donations').dataTable({
                language: { url: "/resources/dataTable." + "@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName.ToUpperInvariant()" + ".json" },
                orderCellsTop: true,
                autoWidth: true,
                data: data,
                columns: [
                    { "data": "Id" },
                    { "data": "Created" },
                    { "data": "Amount", render: $.fn.dataTable.render.number(',', '.', 2, '', ' €') },
                    { "data": "FoodBank" },
                    {
                        "data": "Payment",
                        "render": function (data) {
                            var paymentStatus = {
                                Payed: "@Localizer["Payed"]",
                                NotPayed: "@Localizer["NotPayed"]",
                                WaitingPayment: "@Localizer["WaitingPayment"]",
                                ErrorPayment: "@Localizer["ErrorPayment"]"
                            };

                            if (paymentStatus.hasOwnProperty(data)) {
                                return paymentStatus[data];
                            }

                            return data;
                        }
                    },
                ]
            });
        });
});

    </script>
}
