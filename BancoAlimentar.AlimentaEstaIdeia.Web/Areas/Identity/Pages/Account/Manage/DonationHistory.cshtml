@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Identity.Pages.Account.Manage.DonationHistoryModel
@using System.Text.Json
@{
    var donationHistoryI18n = new Dictionary<string, object>
    {
        ["emptyTable"] = Localizer["DataTableEmptyTable"].Value,
        ["processing"] = Localizer["DataTableProcessing"].Value,
        ["lengthMenu"] = Localizer["DataTableLengthMenu"].Value,
        ["zeroRecords"] = Localizer["DataTableZeroRecords"].Value,
        ["search"] = Localizer["DataTableSearch"].Value,
        ["info"] = Localizer["DataTableInfo"].Value,
        ["infoEmpty"] = Localizer["DataTableInfoEmpty"].Value,
        ["paginateFirst"] = Localizer["DataTablePaginateFirst"].Value,
        ["paginatePrevious"] = Localizer["DataTablePaginatePrevious"].Value,
        ["paginateNext"] = Localizer["DataTablePaginateNext"].Value,
        ["paginateLast"] = Localizer["DataTablePaginateLast"].Value,
        ["searchHelpTooltip"] = Localizer["SearchHelpTooltip"].Value,
        ["details"] = Localizer["Details"].Value,
        ["donationInvoice"] = Localizer["DonationInvoice"].Value,
        ["invalidNif"] = Localizer["InvalidNIF"].Value,
        ["paymentPendingStatus"] = Localizer["PaymentPendingStatus"].Value,
        ["completeDonation"] = Localizer["CompleteDonation"].Value,
        ["paymentTypes"] = new Dictionary<string, string>
        {
            ["CreditCard"] = IdentitySharedLocalizer["CreditCard"].Value,
        },
        ["paymentStatuses"] = new Dictionary<string, string>
        {
            ["Payed"] = IdentitySharedLocalizer["Payed"].Value,
        },
    };
}
@section Css {
    <environment include="Development">
        <link href="~/lib/datatables/css/jquery.dataTables.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-bs4/dataTables.bootstrap4.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.css" rel="stylesheet" />
    </environment>
    <environment exclude="Development">
        <link href="~/lib/datatables/css/jquery.dataTables.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-bs4/dataTables.bootstrap4.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-buttons-bs4/buttons.bootstrap4.min.css" rel="stylesheet" />
        <link href="~/lib/datatables.net-responsive-bs4/responsive.bootstrap4.min.css" rel="stylesheet" />
    </environment>
    <style>
        #donationHistory thead th.donation-history-th {
            font-size: 0.8125rem;
            line-height: 1.15;
            padding: 0.35rem 0.25rem;
            text-align: center;
            vertical-align: bottom;
        }

        #donationHistory thead th .donation-history-th-label {
            display: inline-block;
            white-space: normal;
        }
    </style>
}

<div class="container">
    <div>@Localizer["SummaryDonatedIntro"] <b>@Model.GetsDonatedFirstDateString</b> @Localizer["SummaryDonatedIntro2"] <b>@Model.GetsDonatedCount</b> @Localizer["SummaryDonatedIntro3"] <b>@Math.Round(Model.GetsDonatedTotal,2)</b> €</div>
    <br />

    <script type="application/json" id="donation-history-i18n">@Html.Raw(JsonSerializer.Serialize(donationHistoryI18n))</script>

    <table id="donationHistory" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
        <thead>
            <tr>
                <th class="donation-history-th">#</th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationDateTimeHeaderLine1"]<br />@Localizer["DonationDateTimeHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationFoodBankHeaderLine1"]<br />@Localizer["DonationFoodBankHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationAmountHeaderLine1"]<br />@Localizer["DonationAmountHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationPaymentTypeHeaderLine1"]<br />@Localizer["DonationPaymentTypeHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationPaymentStatusHeaderLine1"]<br />@Localizer["DonationPaymentStatusHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["SubscriptionHeaderLine1"]<br />@Localizer["SubscriptionHeaderLine2"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["DonationInvoice"]</span></th>
                <th class="donation-history-th"><span class="donation-history-th-label">@Localizer["CompleteDonationHeaderLine1"]<br />@Localizer["CompleteDonationHeaderLine2"]</span></th>
            </tr>
        </thead>
    </table>

</div>
