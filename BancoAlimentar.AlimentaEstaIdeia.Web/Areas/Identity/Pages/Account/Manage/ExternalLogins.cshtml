@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Manage your external logins";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<partial name="_StatusMessage" for="StatusMessage" />

@if (Model.ShowMergeOffer)
{
    <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading">@Localizer["MergeOfferTitle"]</h5>
        <p>@Localizer["MergeOfferMessage", Model.MergeProviderDisplayName, Model.MaskedSourceEmail]</p>
        <p class="mb-0">@Localizer["MergeOfferDetails"]</p>
        <hr />
        <div class="d-flex flex-column flex-sm-row flex-wrap">
            <form asp-page-handler="ConfirmMerge" method="post" class="mb-2 mr-sm-2">
                <button type="submit" class="btn btn-primary">@Localizer["ConfirmMergeAction"]</button>
            </form>
            <form asp-page-handler="CancelLink" method="post" class="mb-2">
                <button type="submit" class="btn btn-outline-secondary">@Localizer["CancelMergeAction"]</button>
            </form>
        </div>
    </div>
}
else if (Model.ShowLinkConflictHelp)
{
    <div class="alert alert-warning" role="alert">
        <h5 class="alert-heading">@Localizer["LinkConflictTitle", Model.MergeProviderDisplayName]</h5>
        @switch (Model.LinkConflictBlockReason)
        {
            case nameof(AccountMergeBlockReason.EmailMismatch):
                <p>@Localizer["LinkConflictEmailMismatch", Model.MergeProviderDisplayName, Model.MaskedExternalEmail, Model.MaskedSourceEmail]</p>
                break;
            case nameof(AccountMergeBlockReason.ProtectedAccount):
                <p>@Localizer["LinkConflictProtectedAccount", Model.MergeProviderDisplayName]</p>
                break;
            case nameof(AccountMergeBlockReason.MissingExternalEmail):
                <p>@Localizer["LinkConflictMissingExternalEmail", Model.MergeProviderDisplayName]</p>
                break;
            default:
                <p>@Localizer["LinkConflictGeneric", Model.MergeProviderDisplayName]</p>
                break;
        }
        <hr />
        <p class="mb-2"><strong>@Localizer["LinkConflictSolutionsTitle"]</strong></p>
        <ul class="mb-0">
            <li>@Localizer["LinkConflictSolutionSignInWithProvider", Model.MergeProviderDisplayName]</li>
            <li>@Localizer["LinkConflictSolutionUseMatchingEmail", Model.MergeProviderDisplayName]</li>
            <li>@Localizer["LinkConflictSolutionRemoveFromOtherAccount", Model.MergeProviderDisplayName]</li>
        </ul>
        <hr />
        <form asp-page-handler="CancelLink" method="post">
            <button type="submit" class="btn btn-outline-secondary">@Localizer["CancelMergeAction"]</button>
        </form>
    </div>
}

@if (Model.CurrentLogins?.Count > 0)
{
<h4>@IdentitySharedLocalizer["RegisteredLogins"]</h4>
    <table class="table">
        <tbody>
            @foreach (var login in Model.CurrentLogins)
            {
                <tr>
                    <td id="@($"login-provider-{login.LoginProvider}")">@login.ProviderDisplayName</td>
                    <td>
                        @if (Model.ShowRemoveButton)
                        {
                            <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                <div>
                                    <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                    <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                    <button type="submit" class="btn btn-primary" title="Remove this @login.ProviderDisplayName login from your account">Remove</button>
                                </div>
                            </form>
                        }
                        else
                        {
                            @: &nbsp;
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
@if (Model.OtherLogins?.Count > 0)
{
<h4>@IdentitySharedLocalizer["AddAnotherService"]</h4>
    <hr />
    <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="form-horizontal">
        <div id="socialLoginList">
            <p>
                @foreach (var provider in Model.OtherLogins)
                {
                    <button id="@($"link-login-button-{provider.Name}")" type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                }
            </p>
        </div>
    </form>
}
