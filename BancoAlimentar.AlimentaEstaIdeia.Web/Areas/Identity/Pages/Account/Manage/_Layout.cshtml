@using BancoAlimentar.AlimentaEstaIdeia.Sas.Core.Layout
@inject ITenantLayout tenantLayoutManager
@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout))
    {
        Layout = (string)parentLayout;
    }
    else
    {
        Layout = tenantLayoutManager.AdminLayout;
    }
}

@section Css {
    @RenderSection("Css", required: false)
}


<h2>@IdentitySharedLocalizer["ManageAccount"]</h2>

<div>
    <h4>@IdentitySharedLocalizer["ManageAccountMessage"]</h4>
    <hr />
    <div class="row">
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-md-9">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
