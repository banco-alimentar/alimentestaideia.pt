@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.ClearTenantStaticCacheModel
@{
}

<h1>@Localizer["Title"]</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.StatusMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

<p>@Localizer["Description"]</p>

@if (Model.LastResult != null)
{
    <div class="alert alert-info" role="alert">
        @AdminSharedLocalizer["CacheFolder"] <code>@Model.LastResult.CacheRootPath</code><br />
        @AdminSharedLocalizer["FilesRemoved"] @Model.LastResult.FilesRemoved<br />
        @AdminSharedLocalizer["FilesDownloaded"] @Model.LastResult.FilesDownloaded
    </div>
}

<p class="text-muted">@Localizer["InstanceScopeNote"]</p>

<h2 class="h4">@Localizer["ActionsHeading"]</h2>

<div class="row">
    <div class="col-lg-6 mb-3">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h3 class="h5 card-title">@Localizer["ClearLocalCacheTitle"]</h3>
                <p class="card-text">@Localizer["ClearLocalCacheDescription"]</p>
                <form method="post" asp-page-handler="Clear" class="mt-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">@AdminSharedLocalizer["ClearLocalCache"]</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-6 mb-3">
        <div class="card h-100 border-primary">
            <div class="card-body d-flex flex-column">
                <h3 class="h5 card-title">
                    @Localizer["ClearAndResyncTitle"]
                    <span class="badge bg-primary ms-1">@Localizer["RecommendedBadge"]</span>
                </h3>
                <p class="card-text">@Localizer["ClearAndResyncDescription"]</p>
                <form method="post" asp-page-handler="ClearAndResync" class="mt-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">@AdminSharedLocalizer["ClearAndResync"]</button>
                </form>
            </div>
        </div>
    </div>
</div>
