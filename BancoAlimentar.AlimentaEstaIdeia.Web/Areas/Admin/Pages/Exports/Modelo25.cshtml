@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Exports.Modelo25Model

@{
    ViewData["Title"] = AdminSharedLocalizer["Modelo25ExportTitle"].Value;
}

<h1>@AdminSharedLocalizer["Modelo25ExportTitle"]</h1>

<p class="text-muted">@AdminSharedLocalizer["Modelo25ExportIntro"]</p>

<form method="post" asp-page-handler="Export">
    <div class="mb-3">
        <label class="form-label" asp-for="Year">@AdminSharedLocalizer["Year"]</label>
        <select class="form-select" asp-for="Year" asp-items="Model.YearOptions">
            <option value="">@AdminSharedLocalizer["SelectYear"]</option>
        </select>
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">@AdminSharedLocalizer["ExportModelo25Excel"]</button>
</form>

<p class="mt-3">
    <a asp-page="./Index">@AdminSharedLocalizer["BackToExports"]</a>
</p>
