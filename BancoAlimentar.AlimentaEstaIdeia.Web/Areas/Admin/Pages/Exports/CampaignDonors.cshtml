@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Exports.CampaignDonorsModel

@{
    ViewData["Title"] = AdminSharedLocalizer["CampaignDonorsExportTitle"].Value;
}

<h1>@AdminSharedLocalizer["CampaignDonorsExportTitle"]</h1>

<p class="text-muted">@AdminSharedLocalizer["CampaignDonorsExportIntro"]</p>

<form method="post" asp-page-handler="Export">
    <div class="mb-3">
        <label class="form-label" asp-for="CampaignId">@AdminSharedLocalizer["Campaign"]</label>
        <select class="form-select" asp-for="CampaignId" asp-items="Model.CampaignOptions">
            <option value="">@AdminSharedLocalizer["SelectCampaign"]</option>
        </select>
        <span asp-validation-for="CampaignId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">@AdminSharedLocalizer["ExportDonorsCsv"]</button>
</form>

<p class="mt-3">
    <a asp-page="./Index">@AdminSharedLocalizer["BackToExports"]</a>
</p>
