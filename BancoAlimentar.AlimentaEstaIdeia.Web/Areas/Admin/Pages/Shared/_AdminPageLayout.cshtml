@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    string currentPage = ViewContext.RouteData.Values["page"] as string;
    bool isAdminHome = string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase);
}

@if (!isAdminHome)
{
    <p class="mb-3">
        <a asp-area="Admin" asp-page="/Index"><i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>@AdminSharedLocalizer["BackToAdminHome"]</a>
    </p>
}

@RenderBody()

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
