@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Campaigns.ShowModel
@{
}
<h1>@AdminSharedLocalizer["CurrentCampaign"]</h1>

<div>
    <h4>@AdminSharedLocalizer["Campaign"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Start"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => Model.CurrentCampaign.Start)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["End"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => Model.CurrentCampaign.End)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["ReportEnd"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => Model.CurrentCampaign.ReportEnd)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Number"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => Model.CurrentCampaign.Number)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["CurrentDateTime"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => Model.CurrentDateTime)
        </dd>
    </dl>
</div>
