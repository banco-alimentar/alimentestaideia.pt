@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Campaigns.DetailsModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Details"].Value;
}

<h1>@AdminSharedLocalizer["Details"]</h1>

<div>
    <h4>@AdminSharedLocalizer["Campaign"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Number"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.Number)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Start"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.Start)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["End"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.End)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["ReportEnd"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.ReportEnd)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["IsDefaultCampaign"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.IsDefaultCampaign)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Campaign.Id">@AdminSharedLocalizer["Edit"]</a> |
    <a asp-page="./Index">@AdminSharedLocalizer["BackToList"]</a>
</div>
