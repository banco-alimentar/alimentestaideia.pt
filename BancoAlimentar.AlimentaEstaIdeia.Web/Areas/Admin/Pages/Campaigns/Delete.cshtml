@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Campaigns.DeleteModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Delete"].Value;
}

<h1>@AdminSharedLocalizer["Delete"]</h1>

<h3>@AdminSharedLocalizer["DeleteConfirmation"]</h3>
<div>
    <h4>@AdminSharedLocalizer["Campaign"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Number"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.Number)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Start"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.Start)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["End"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.End)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["ReportEnd"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.ReportEnd)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["IsDefaultCampaign"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Campaign.IsDefaultCampaign)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Campaign.Id" />
        <input type="submit" value="@AdminSharedLocalizer["Delete"].Value" class="btn btn-danger" /> |
        <a asp-page="./Index">@AdminSharedLocalizer["BackToList"]</a>
    </form>
</div>
