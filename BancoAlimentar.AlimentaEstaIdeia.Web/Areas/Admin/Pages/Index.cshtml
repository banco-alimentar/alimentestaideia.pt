@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.IndexModel
@{
}

<h1>@Localizer["AdministrationWebSite"]</h1>

<p>@Localizer["Intro"]</p>

<ul class="list-unstyled">
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-file-invoice" }, { "Page", "./CancelInvoice" }, { "Text", Localizer["CancelInvoiceLink"].Value }, { "Description", Localizer["CancelInvoiceDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-hand-holding-heart" }, { "Page", "./Donations/Index" }, { "Text", Localizer["DonationsLink"].Value }, { "Description", Localizer["DonationsDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-search-dollar" }, { "Page", "./SearchEasypay" }, { "Text", Localizer["SearchEasypayLink"].Value }, { "Description", Localizer["SearchEasypayDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-sync-alt" }, { "Page", "./Subscriptions/Index" }, { "Text", Localizer["SubscriptionsLink"].Value }, { "Description", Localizer["SubscriptionsDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-exclamation-triangle" }, { "Page", "./Errors/Index" }, { "Text", Localizer["ErrorsLink"].Value }, { "Description", Localizer["ErrorsDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-box-open" }, { "Page", "./ProductsCatalogues/Index" }, { "Text", Localizer["ProductsCataloguesLink"].Value }, { "Description", Localizer["ProductsCataloguesDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-bullhorn" }, { "Page", "./Campaigns/Index" }, { "Text", Localizer["CampaignsLink"].Value }, { "Description", Localizer["CampaignsDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-chart-bar" }, { "Page", "./GenerateDonationReport" }, { "Text", Localizer["GenerateReportLink"].Value }, { "Description", Localizer["GenerateReportDescription"].Value } }' />
    <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-file-export" }, { "Page", "./Exports/Index" }, { "Text", Localizer["ExportsLink"].Value }, { "Description", Localizer["ExportsDescription"].Value } }' />
    @if (User.IsInRole("SuperAdmin"))
    {
        <partial name="Shared/_AdminNavItem" view-data='new ViewDataDictionary(ViewData) { { "Icon", "fa-user-shield" }, { "Page", "./SuperAdmin" }, { "Text", Localizer["SuperAdminLink"].Value }, { "Description", Localizer["SuperAdminDescription"].Value } }' />
    }
</ul>
