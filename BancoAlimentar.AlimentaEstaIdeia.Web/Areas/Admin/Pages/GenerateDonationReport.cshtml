@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.GenerateDonationReportModel
@{
}

<h1>Donation analytics report</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.StatusMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

@if (Model.LastResult?.Succeeded == true)
{
    <div class="alert alert-info" role="alert">
        @Model.LastResult.Message
        <div class="mt-2">
            Paid total: @Model.LastResult.TotalPaidAmount.ToString("C2")
            (@Model.LastResult.PaidDonationCount donations).
            Generated at @Model.LastResult.GeneratedAtUtc.ToString("u") UTC.
        </div>
    </div>
}

<p>
    Generates static HTML donation analytics and publishes them to tenant blob storage
    (served at <a href="@BancoAlimentar.AlimentaEstaIdeia.Repository.Reporting.DonationReportPaths.PublicPath" target="_blank" rel="noopener noreferrer">@BancoAlimentar.AlimentaEstaIdeia.Repository.Reporting.DonationReportPaths.PublicPath</a>).
    Files are also written to <code>wwwroot/report</code> on this app instance.
</p>

@if (Model.IsBackgroundRunning)
{
    <p class="text-muted">A background report generation is currently in progress.</p>
}

<form method="post" asp-page-handler="GenerateNow" class="d-inline">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-primary" @(Model.IsBackgroundRunning ? "disabled" : null)>Generate now</button>
</form>

<form method="post" asp-page-handler="Enqueue" class="d-inline ms-2">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-secondary" @(Model.IsBackgroundRunning ? "disabled" : null)>Generate in background</button>
</form>

<p class="mt-3">
    <a asp-page="./Index">Back to admin home</a>
</p>
