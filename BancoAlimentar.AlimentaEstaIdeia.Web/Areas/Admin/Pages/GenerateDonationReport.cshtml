@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.GenerateDonationReportModel
@{
}

<h1>@Localizer["Title"]</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.StatusMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

@if (Model.LastResult?.Succeeded == true)
{
    <div class="alert alert-info" role="alert">
        @Model.LastResult.Message
        <div class="mt-2">
            @AdminSharedLocalizer["PaidTotal"] @Model.LastResult.TotalPaidAmount.ToString("C2")
            (@Model.LastResult.PaidDonationCount @AdminSharedLocalizer["DonationsSuffix"]
            @AdminSharedLocalizer["GeneratedAt"] @Model.LastResult.GeneratedAtUtc.ToString("u") @AdminSharedLocalizer["UtcSuffix"]
        </div>
    </div>
}

<div class="alert alert-secondary" role="status">
    @Localizer["DatabaseSource"] <strong><code>@Model.DatabaseName</code></strong>
</div>

<p>
    @Localizer["Description"]<a href="@BancoAlimentar.AlimentaEstaIdeia.Repository.Reporting.DonationReportPaths.PublicPath" target="_blank" rel="noopener noreferrer">@BancoAlimentar.AlimentaEstaIdeia.Repository.Reporting.DonationReportPaths.PublicPath</a>@Localizer["DescriptionEnd"]
</p>

@if (Model.IsBackgroundRunning)
{
    <p class="text-muted">@Localizer["BackgroundRunning"]</p>
}

<form method="post" asp-page-handler="GenerateNow" class="d-inline">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-primary" @(Model.IsBackgroundRunning ? "disabled" : null)>@Localizer["GenerateNow"]</button>
</form>

<form method="post" asp-page-handler="Enqueue" class="d-inline ms-2">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-secondary" @(Model.IsBackgroundRunning ? "disabled" : null)>@Localizer["GenerateBackground"]</button>
</form>

<p class="mt-3">
    <a asp-page="./Index">@AdminSharedLocalizer["BackToAdminHome"]</a>
</p>
