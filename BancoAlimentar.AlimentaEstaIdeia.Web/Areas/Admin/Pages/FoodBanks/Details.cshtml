@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.FoodBanks.DetailsModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Details"].Value;
}

<h1>@AdminSharedLocalizer["Details"]</h1>

<div>
    <h4>@AdminSharedLocalizer["FoodBank"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Name"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FoodBank.Name)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.FoodBank.Id">@AdminSharedLocalizer["Edit"]</a> |
    <a asp-page="./Index">@AdminSharedLocalizer["BackToList"]</a>
</div>
