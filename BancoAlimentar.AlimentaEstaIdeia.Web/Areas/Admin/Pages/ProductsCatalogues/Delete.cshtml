@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.ProductsCatalogues.DeleteModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Delete"].Value;
}

<h1>@AdminSharedLocalizer["Delete"]</h1>

<h3>@AdminSharedLocalizer["DeleteConfirmation"]</h3>
<div>
    <h4>@AdminSharedLocalizer["ProductCatalogue"]</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Name"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.Name)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Description"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.Description)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["UnitOfMeasure"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.UnitOfMeasure)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Cost"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.Cost)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["IconUrl"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.IconUrl)
        </dd>
        <dt class="col-sm-2">
            @AdminSharedLocalizer["Quantity"]
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductCatalogue.Quantity)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="ProductCatalogue.Id" />
        <input type="submit" value="@AdminSharedLocalizer["Delete"].Value" class="btn btn-danger" /> |
        <a asp-page="./Index">@AdminSharedLocalizer["BackToList"]</a>
    </form>
</div>
