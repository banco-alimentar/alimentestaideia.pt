@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Errors.NoCompletedDatePayPalModel

@{
    ViewData["Title"] = AdminSharedLocalizer["ErrorNoCompletedDatePayPalTitle"].Value;
}

<h1>@AdminSharedLocalizer["ErrorNoCompletedDatePayPalTitle"]</h1>
<p class="text-muted">@AdminSharedLocalizer["ErrorNoCompletedDatePayPalIntro"]</p>
<p><a asp-page="./Index">@AdminSharedLocalizer["AdminErrorsTitle"]</a></p>

<partial name="_AdminErrorSql" model="Model.SqlQuery" />

@if (Model.Rows.Count == 0)
{
    <p class="text-muted">@AdminSharedLocalizer["ErrorNoCompletedDatePayPalNone"]</p>
}
else
{
    <p class="text-muted mb-3">@Model.Rows.Count @AdminSharedLocalizer["ErrorNoCompletedDatePayPalCountSuffix"]</p>
    <partial name="_DonationPaymentIssuesTable" model="Model.Rows" />
}
