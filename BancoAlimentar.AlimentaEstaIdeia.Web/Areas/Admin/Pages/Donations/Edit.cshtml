@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Donations.EditModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Edit"].Value;
}

<h1>@AdminSharedLocalizer["Edit"]</h1>

<h4>@AdminSharedLocalizer["Donation"]</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Input.Id" />
            <dl class="row mb-3">
                <dt class="col-sm-5">@AdminSharedLocalizer["PublicId"]</dt>
                <dd class="col-sm-7">@Model.PublicId</dd>
                <dt class="col-sm-5">@AdminSharedLocalizer["DonationAmount"]</dt>
                <dd class="col-sm-7">@Model.DonationAmount</dd>
                <dt class="col-sm-5">@AdminSharedLocalizer["PaymentStatus"]</dt>
                <dd class="col-sm-7">@Model.PaymentStatus</dd>
            </dl>
            <p class="text-muted small">
                @AdminSharedLocalizer["AmountPaymentReadOnlyHelp"]
            </p>
            <div class="form-group">
                <label asp-for="Input.DonationDate" class="control-label"></label>
                <input asp-for="Input.DonationDate" class="form-control" />
                <span asp-validation-for="Input.DonationDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.WantsReceipt" class="control-label"></label>
                <input asp-for="Input.WantsReceipt" class="form-control" />
                <span asp-validation-for="Input.WantsReceipt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ServiceEntity" class="control-label"></label>
                <input asp-for="Input.ServiceEntity" class="form-control" />
                <span asp-validation-for="Input.ServiceEntity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ServiceReference" class="control-label"></label>
                <input asp-for="Input.ServiceReference" class="form-control" />
                <span asp-validation-for="Input.ServiceReference" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="@AdminSharedLocalizer["Save"].Value" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">@AdminSharedLocalizer["BackToList"]</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
