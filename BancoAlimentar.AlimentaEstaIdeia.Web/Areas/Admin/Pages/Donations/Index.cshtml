@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Donations.IndexModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Index"].Value;
}

<h1>@AdminSharedLocalizer["Index"]</h1>

<table class="table">
    <thead>
        <tr>
            <th>
                @AdminSharedLocalizer["DonationDate"]
            </th>
            <th>
                @AdminSharedLocalizer["DonationAmount"]
            </th>
            <th>
                @AdminSharedLocalizer["WantsReceipt"]
            </th>
            <th>
                @AdminSharedLocalizer["ReferralCode"]
            </th>
            <th>
                @AdminSharedLocalizer["PaymentStatus"]
            </th>
            <th>
                @AdminSharedLocalizer["ServiceEntity"]
            </th>
            <th>
                @AdminSharedLocalizer["ServiceReference"]
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Donation) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DonationDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DonationAmount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WantsReceipt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReferralEntity.Code)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PaymentStatus)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ServiceEntity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ServiceReference)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">@AdminSharedLocalizer["Edit"]</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">@AdminSharedLocalizer["Details"]</a> |                
            </td>
        </tr>
}
    </tbody>
</table>
