@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.Donations.IndexModel

@{
    ViewData["Title"] = AdminSharedLocalizer["Index"].Value;
}

<h1>@AdminSharedLocalizer["Index"]</h1>

<form method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-4 col-lg-2">
            <label class="form-label" for="serviceReferenceSearch">@AdminSharedLocalizer["ServiceReference"]</label>
            <input type="search"
                   id="serviceReferenceSearch"
                   name="serviceReferenceSearch"
                   value="@Model.ServiceReferenceSearch"
                   class="form-control"
                   maxlength="20" />
        </div>
        <div class="col-md-4 col-lg-2">
            <label class="form-label" for="nifSearch">@AdminSharedLocalizer["Nif"]</label>
            <input type="search"
                   id="nifSearch"
                   name="nifSearch"
                   value="@Model.NifSearch"
                   class="form-control"
                   maxlength="20" />
        </div>
        <div class="col-md-4 col-lg-3">
            <label class="form-label" for="emailSearch">@AdminSharedLocalizer["Email"]</label>
            <input type="search"
                   id="emailSearch"
                   name="emailSearch"
                   value="@Model.EmailSearch"
                   class="form-control"
                   maxlength="256" />
        </div>
        <div class="col-md-4 col-lg-2">
            <label class="form-label" for="amountSearch">@AdminSharedLocalizer["DonationAmount"]</label>
            <input type="search"
                   id="amountSearch"
                   name="amountSearch"
                   value="@Model.AmountSearch"
                   class="form-control"
                   inputmode="decimal"
                   maxlength="20" />
        </div>
        <div class="col-md-4 col-lg-2">
            <label class="form-label" for="donationDateSearch">@AdminSharedLocalizer["DonationDate"]</label>
            <input type="date"
                   id="donationDateSearch"
                   name="donationDateSearch"
                   value="@(Model.DonationDateSearch?.ToString("yyyy-MM-dd"))"
                   class="form-control" />
        </div>
        <div class="col-md-4 col-lg-3">
            <label class="form-label" for="publicIdSearch">@AdminSharedLocalizer["PublicId"]</label>
            <input type="search"
                   id="publicIdSearch"
                   name="publicIdSearch"
                   value="@Model.PublicIdSearch"
                   class="form-control"
                   maxlength="36"
                   placeholder="e.g. dde6e67d-6302-47b4-b498-5a833f20c4c3" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">@AdminSharedLocalizer["Search"]</button>
            @if (Model.HasActiveFilters)
            {
                <a asp-page="./Index" class="btn btn-outline-secondary">@AdminSharedLocalizer["ClearSearch"]</a>
            }
        </div>
    </div>
    <input type="hidden" name="pageIndex" value="1" />
</form>

@if (Model.TotalCount == 0)
{
    <p class="text-muted">
        @(Model.HasActiveFilters
            ? AdminSharedLocalizer["DonationsNoResultsWithFilters"]
            : AdminSharedLocalizer["NoDonationsFound"])
    </p>
}
else
{
    <p class="text-muted mb-3">
        @AdminSharedLocalizer["Showing"]
        @(((Model.PageIndex - 1) * Model.DonationsPerPage) + 1)–@(Math.Min(Model.PageIndex * Model.DonationsPerPage, Model.TotalCount))
        @AdminSharedLocalizer["PaginationOf"] @Model.TotalCount @AdminSharedLocalizer["DonationsLabel"]
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>@AdminSharedLocalizer["DonationDate"]</th>
                <th>@AdminSharedLocalizer["DonationAmount"]</th>
                <th>@AdminSharedLocalizer["Nif"]</th>
                <th>@AdminSharedLocalizer["WantsReceipt"]</th>
                <th>@AdminSharedLocalizer["ReferralCode"]</th>
                <th>@AdminSharedLocalizer["PaymentStatus"]</th>
                <th>@AdminSharedLocalizer["ServiceEntity"]</th>
                <th>@AdminSharedLocalizer["ServiceReference"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model.Donation) {
            var nif = !string.IsNullOrEmpty(item.Nif) ? item.Nif : item.User?.Nif;
            <tr>
                <td>@Html.DisplayFor(modelItem => item.DonationDate)</td>
                <td>@Html.DisplayFor(modelItem => item.DonationAmount)</td>
                <td>
                    @if (item.User != null && !string.IsNullOrEmpty(nif))
                    {
                        <a asp-area="Admin" asp-page="/Users/Details" asp-route-id="@item.User.Id">@nif</a>
                    }
                    else if (!string.IsNullOrEmpty(nif))
                    {
                        @nif
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.WantsReceipt)</td>
                <td>@Html.DisplayFor(modelItem => item.ReferralEntity.Code)</td>
                <td>@Html.DisplayFor(modelItem => item.PaymentStatus)</td>
                <td>@Html.DisplayFor(modelItem => item.ServiceEntity)</td>
                <td>@Html.DisplayFor(modelItem => item.ServiceReference)</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">@AdminSharedLocalizer["Edit"]</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">@AdminSharedLocalizer["Details"]</a>
                </td>
            </tr>
    }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Donations pagination">
            <ul class="pagination">
                <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-route-pageIndex="@(Model.PageIndex - 1)"
                       asp-route-serviceReferenceSearch="@Model.ServiceReferenceSearch"
                       asp-route-nifSearch="@Model.NifSearch"
                       asp-route-emailSearch="@Model.EmailSearch"
                       asp-route-amountSearch="@Model.AmountSearch"
                       asp-route-donationDateSearch="@(Model.DonationDateSearch?.ToString("yyyy-MM-dd"))"
                       asp-route-publicIdSearch="@Model.PublicIdSearch"
                       aria-disabled="@(!Model.HasPreviousPage)">@AdminSharedLocalizer["Previous"]</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@AdminSharedLocalizer["Page"] @Model.PageIndex @AdminSharedLocalizer["PaginationOf"] @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-route-pageIndex="@(Model.PageIndex + 1)"
                       asp-route-serviceReferenceSearch="@Model.ServiceReferenceSearch"
                       asp-route-nifSearch="@Model.NifSearch"
                       asp-route-emailSearch="@Model.EmailSearch"
                       asp-route-amountSearch="@Model.AmountSearch"
                       asp-route-donationDateSearch="@(Model.DonationDateSearch?.ToString("yyyy-MM-dd"))"
                       asp-route-publicIdSearch="@Model.PublicIdSearch"
                       aria-disabled="@(!Model.HasNextPage)">@AdminSharedLocalizer["Next"]</a>
                </li>
            </ul>
        </nav>
    }
}

<p class="mt-3">
    <a asp-page="../Index">@AdminSharedLocalizer["BackToAdminHome"]</a>
</p>
