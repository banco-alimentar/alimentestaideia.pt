@page
@model BancoAlimentar.AlimentaEstaIdeia.Web.Areas.Admin.Pages.ReloadSettingsModel
@{
}

<h1>@Localizer["Title"]</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.StatusMessage
    </div>
}

<p>
    @Localizer["Description"]
</p>

<form method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-primary">@Localizer["Submit"]</button>
</form>

<p class="mt-3">
    <a asp-page="./SuperAdmin">@AdminSharedLocalizer["BackToSuperAdmin"]</a>
</p>
